{
  "name": "anto426-vscode-theme",
  "displayName": "Anto426 Rofi Dynamic",
  "description": "Dynamic VS Code theme aligned with the Anto426 Rofi design.",
  "version": "0.1.0",
  "publisher": "Anto426",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Arch-repo/vscodetheme/issues"
  },
  "homepage": "https://github.com/Arch-repo/vscodetheme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Arch-repo/vscodetheme"
  },
  "engines": {
    "vscode": "^1.76.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "browser": "./out/web/extension.js",
  "categories": [
    "Themes"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "eslintConfig": {
    "extends": [
      "@mskelton",
      "@mskelton/eslint-config/typescript"
    ],
    "plugins": [
      "html"
    ],
    "rules": {
      "sort/imports": "off"
    }
  },
  "scripts": {
    "docs": "docsify serve docs",
    "build:theme": "ts-node --project scripts/tsconfig.json scripts/generate-theme.ts",
    "build:ts": "tsc -p src && mkdir -p out/webview && cp -r src/webview-assets/* out/webview/",
    "build": "yarn build:sass && yarn build:theme && yarn build:ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "watch:theme": "nodemon ./scripts/generate-theme.ts",
    "watch:ts": "yarn build:ts -w",
    "vscode:prepublish": "yarn build",
    "package": "vsce package",
    "build:sass": "yarn sass --no-source-map scss:styles && yarn sass --no-source-map scss:styles/origin",
    "compile-web": "webpack --config ./build/web-extension.webpack.config.js",
    "watch-web": "webpack --watch --config ./build/web-extension.webpack.config.js",
    "package-web": "webpack --mode production --devtool hidden-source-map --config ./build/web-extension.webpack.config.js"
  },
  "prettier": {
    "singleQuote": true,
    "semi": false
  },
  "contributes": {
    "markdown.previewStyles": [
      "./styles/base-inside.css",
      "./styles/markdown-inside.css",
      "./styles/atom-one-dark-inside.css"
    ],
    "commands": [
      {
        "command": "oneDarkPro.showChangelog",
        "title": "%description.oneDarkPro.showChangelog%",
        "category": "Anto426 Rofi Dynamic"
      },
      {
        "command": "oneDarkPro.setVivid",
        "title": "%description.oneDarkPro.setVivid%",
        "category": "Anto426 Rofi Dynamic"
      },
      {
        "command": "oneDarkPro.cancelVivid",
        "title": "%description.oneDarkPro.cancelVivid%",
        "category": "Anto426 Rofi Dynamic"
      },
      {
        "command": "oneDarkPro.setItalic",
        "title": "%description.oneDarkPro.setItalic%",
        "category": "Anto426 Rofi Dynamic"
      },
      {
        "command": "oneDarkPro.cancelItalic",
        "title": "%description.oneDarkPro.cancelItalic%",
        "category": "Anto426 Rofi Dynamic"
      },
      {
        "command": "oneDarkPro.setBold",
        "title": "%description.oneDarkPro.setBold%",
        "category": "Anto426 Rofi Dynamic"
      },
      {
        "command": "oneDarkPro.cancelBold",
        "title": "%description.oneDarkPro.cancelBold%",
        "category": "Anto426 Rofi Dynamic"
      },
      {
        "command": "bootty.newTerminal",
        "title": "BooTTY: New Terminal"
      },
      {
        "command": "bootty.newTerminalInEditor",
        "title": "BooTTY: New Terminal in Editor"
      },
      {
        "command": "bootty.newTerminalInPanel",
        "title": "BooTTY: New Terminal in Panel",
        "icon": "$(plus)"
      },
      {
        "command": "bootty.togglePanel",
        "title": "BooTTY: Toggle Terminal Panel"
      },
      {
        "command": "bootty.newTerminalHere",
        "title": "BooTTY: New Terminal Here"
      },
      {
        "command": "bootty.nextTab",
        "title": "BooTTY: Next Terminal Tab"
      },
      {
        "command": "bootty.previousTab",
        "title": "BooTTY: Previous Terminal Tab"
      },
      {
        "command": "bootty.search",
        "title": "BooTTY: Find in Terminal"
      },
      {
        "command": "bootty.splitTerminal",
        "title": "BooTTY: Split Terminal",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "bootty.openNative",
        "title": "Apri Ghostty Nativo",
        "icon": "$(screen-normal)"
      }
    ],
    "themes": [
      {
        "label": "Anto426 Rofi Dynamic",
        "uiTheme": "vs-dark",
        "path": "./themes/Anto426-Rofi-Dynamic.json"
      }
    ],
    "configuration": {
      "title": "Anto426 Rofi Dynamic",
      "properties": {
        "oneDarkPro.editorTheme": {
          "type": "string",
          "default": "Anto426 Rofi Dynamic",
          "markdownDescription": "%description.oneDarkPro.editorTheme%",
          "enum": [
            "Anto426 Rofi Dynamic"
          ]
        },
        "oneDarkPro.italic": {
          "type": "boolean",
          "default": true,
          "description": "%description.oneDarkPro.italic%"
        },
        "oneDarkPro.vivid": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%description.oneDarkPro.vivid%"
        },
        "oneDarkPro.bold": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%description.oneDarkPro.bold%"
        },
        "oneDarkPro.markdownStyle": {
          "type": "boolean",
          "default": true,
          "description": "%description.oneDarkPro.markdownStyle%"
        },
        "oneDarkPro.color": {
          "type": "object",
          "scope": "resource",
          "default": {
            "chalky": "",
            "coral": "",
            "dark": "",
            "error": "",
            "fountainBlue": "",
            "green": "",
            "invalid": "",
            "lightDark": "",
            "lightWhite": "",
            "malibu": "",
            "purple": "",
            "whiskey": "",
            "deepRed": ""
          },
          "properties": {
            "chalky": {
              "type": "string",
              "default": ""
            },
            "coral": {
              "type": "string",
              "default": ""
            },
            "dark": {
              "type": "string",
              "default": ""
            },
            "error": {
              "type": "string",
              "default": ""
            },
            "fountainBlue": {
              "type": "string",
              "default": ""
            },
            "green": {
              "type": "string",
              "default": ""
            },
            "invalid": {
              "type": "string",
              "default": ""
            },
            "lightDark": {
              "type": "string",
              "default": ""
            },
            "lightWhite": {
              "type": "string",
              "default": ""
            },
            "malibu": {
              "type": "string",
              "default": ""
            },
            "purple": {
              "type": "string",
              "default": ""
            },
            "whiskey": {
              "type": "string",
              "default": ""
            },
            "deepRed": {
              "type": "string",
              "default": ""
            }
          },
          "additionalProperties": false,
          "markdownDescription": "Code highlight colors for the Anto426 Rofi Dynamic theme."
        },
        "bootty.fontFamily": {
          "type": "string",
          "default": "",
          "description": "Font family for BooTTY. Leave empty to use editor.fontFamily."
        },
        "bootty.fontSize": {
          "type": "number",
          "default": 0,
          "minimum": 6,
          "maximum": 72,
          "description": "Font size in pixels. Set to 0 to use editor.fontSize."
        },
        "bootty.defaultTerminalLocation": {
          "type": "string",
          "enum": [
            "panel",
            "editor"
          ],
          "default": "panel",
          "description": "Where new terminals open by default"
        },
        "bootty.bell": {
          "type": "string",
          "enum": [
            "visual",
            "none"
          ],
          "default": "visual",
          "description": "Bell notification style. 'visual' shows a flash and status bar notification, 'none' disables all bell feedback."
        },
        "bootty.notifications": {
          "type": "boolean",
          "default": true,
          "description": "Show VS Code notifications from terminal applications (OSC 9 escape sequences)."
        }
      }
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "bootty-terminal-panel",
          "title": "Ghostty",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "bootty-terminal-panel": [
        {
          "id": "boottyTerminalPanel",
          "name": "Terminal",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "bootty.newTerminalHere",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "bootty.openNative",
          "when": "view == boottyTerminalPanel",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "-workbench.action.terminal.toggleTerminal",
        "key": "ctrl+`"
      },
      {
        "command": "-workbench.action.terminal.new",
        "key": "ctrl+shift+`"
      },
      {
        "command": "-actions.find",
        "key": "cmd+f",
        "when": "focusedView == 'boottyTerminalPanel'"
      },
      {
        "command": "-actions.find",
        "key": "ctrl+f",
        "when": "focusedView == 'boottyTerminalPanel'"
      },
      {
        "command": "-actions.find",
        "key": "cmd+f",
        "when": "activeWebviewPanelId == 'boottyTerminal'"
      },
      {
        "command": "-actions.find",
        "key": "ctrl+f",
        "when": "activeWebviewPanelId == 'boottyTerminal'"
      },
      {
        "command": "-workbench.action.nextEditor",
        "key": "cmd+shift+]",
        "when": "focusedView == 'boottyTerminalPanel'"
      },
      {
        "command": "-workbench.action.previousEditor",
        "key": "cmd+shift+[",
        "when": "focusedView == 'boottyTerminalPanel'"
      },
      {
        "command": "bootty.togglePanel",
        "key": "ctrl+`"
      },
      {
        "command": "bootty.newTerminal",
        "key": "ctrl+shift+`"
      },
      {
        "command": "bootty.newTerminalInPanel",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      },
      {
        "command": "bootty.nextTab",
        "key": "ctrl+shift+]",
        "mac": "cmd+shift+]",
        "when": "focusedView == 'boottyTerminalPanel'"
      },
      {
        "command": "bootty.previousTab",
        "key": "ctrl+shift+[",
        "mac": "cmd+shift+[",
        "when": "focusedView == 'boottyTerminalPanel'"
      },
      {
        "command": "bootty.search",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "focusedView == 'boottyTerminalPanel'"
      },
      {
        "command": "bootty.search",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "activeWebviewPanelId == 'boottyTerminal'"
      },
      {
        "command": "bootty.splitTerminal",
        "key": "ctrl+\\",
        "mac": "cmd+\\",
        "when": "focusedView == 'boottyTerminalPanel'"
      }
    ]
  },
  "icon": "icon.png",
  "keywords": [
    "anto426",
    "rofi",
    "dynamic",
    "wallpaper",
    "theme",
    "hyprland"
  ],
  "devDependencies": {
    "@babel/core": "^7.0.0",
    "@babel/eslint-parser": "^7.0.0",
    "@mskelton/eslint-config": "7.1.0",
    "@mskelton/prettier-config": "5.1.1",
    "@types/node": "16.11.33",
    "@types/vscode": "1.76.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "all-contributors-cli": "6.20.0",
    "docsify-cli": "4.4.4",
    "eslint": "8.14.0",
    "eslint-plugin-html": "6.2.0",
    "eslint-plugin-prettier": "4.0.0",
    "eslint-plugin-sort": "2.4.0",
    "nodemon": "2.0.16",
    "path-browserify": "1.0.1",
    "prettier": "2.6.2",
    "process": "0.11.10",
    "sass": "1.50.1",
    "ts-loader": "9.3.0",
    "ts-node": "10.7.0",
    "typescript": "4.6.4",
    "util": "0.12.5",
    "vsce": "2.7.0",
    "webpack": "5.72.0",
    "webpack-cli": "4.9.2"
  },
  "galleryBanner": {
    "color": "#211b33",
    "theme": "dark"
  },
  "dependencies": {
    "@0xbigboss/ghostty-web": "^0.5.0",
    "@types/marked": "^4.0.1",
    "@vscode/codicons": "^0.0.44",
    "marked": "4",
    "node-pty": "^1.0.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "badges": []
}
